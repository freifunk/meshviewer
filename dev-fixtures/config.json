{
  "siteName": "Meshviewer Local Fixtures",
  "dataPath": ["/fixtures/"],
  "grafana": {
    "url": "./_grafana",
    "orgId": 1
  },
  "nodeCharts": [
    {
      "name": "Traffic",
      "datasourceUid": "fixture",
      "datasourceType": "fixture",
      "query": "SELECT mean(\"rx\") AS RX, mean(\"tx\") AS TX FROM \"traffic\" WHERE \"node\" = '$node' AND $timeFilter GROUP BY time($interval) fill(null)",
      "unitSuffix": "B/s",
      "from": "now-7d",
      "to": "now-1m",
      "maxDataPoints": 300,
      "series": [
        { "name": "RX", "color": "#73BF69" },
        { "name": "TX", "color": "#F2495C", "negate": true }
      ]
    }
  ],
  "fixedCenter": [
    [52.54, 13.0],
    [52.48, 13.45]
  ],
  "mapLayers": [
    {
      "name": "CartoDB",
      "url": "https://cartodb-basemaps-{s}.global.ssl.fastly.net/light_all/{z}/{x}/{y}.png",
      "config": {
        "maxZoom": 22,
        "attribution": "&copy; <a href=\"http://www.openstreetmap.org/copyright\">OpenStreetMap</a>, &copy; | <a href=\"https://carto.com/attribution\">CARTO</a>"
      }
    }
  ]
}
